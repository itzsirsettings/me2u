NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
AUTH_TOKEN_SECRET=generate-a-strong-random-secret-at-least-32-characters
ALLOW_DEMO_WALLET_FUNDING=false
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Separate Me2U Bills API server
PORT=4000
CORS_ORIGIN=http://localhost:3000
REDIS_URL=redis://localhost:6379

# Public platform registration deposit account details. Fill these when ready.
NEXT_PUBLIC_PLATFORM_ACCOUNT_BANK=
NEXT_PUBLIC_PLATFORM_ACCOUNT_NAME=
NEXT_PUBLIC_PLATFORM_ACCOUNT_NUMBER=

# Optional future KYC/NIN verification. Not required for MVP Supabase Auth signup.
NIN_HASH_SECRET=
NIN_VERIFICATION_API_URL=
NIN_VERIFICATION_API_KEY=
NIN_VERIFICATION_AUTH_HEADER=Authorization
NIN_VERIFICATION_AUTH_SCHEME=Bearer
NIN_VERIFICATION_REQUEST_FIELD=nin
NIN_VERIFICATION_TIMEOUT_MS=15000
NIN_VERIFICATION_EXTRA_HEADERS=
NIN_DEMO_NIN=00000000000
NEXT_PUBLIC_NIN_DEMO_NIN=00000000000
NIN_DEMO_FIRST_NAME=Demo
NIN_DEMO_OTHER_NAMES=
NIN_DEMO_LAST_NAME=User
NIN_DEMO_PHONE=08000000000

# SMTP Configuration for sending verification emails (OTP)
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM="Me2U" <noreply@yourdomain.com>

# Paystack configuration for withdrawals and dedicated wallet funding accounts.
PAYSTACK_SECRET_KEY=sk_test_or_live_your_paystack_secret_key
PAYSTACK_DVA_ENABLED=false
PAYSTACK_DVA_PREFERRED_BANK=

# Wema/ALAT primary banking rails. Keep disabled until Wema issues credentials,
# webhook signing rules, endpoint paths, charges, limits, and IP whitelist rules.
WEMA_ENABLED=false
WEMA_BASE_URL=
WEMA_API_KEY=
WEMA_CLIENT_ID=
WEMA_AUTHORIZATION=
WEMA_WEBHOOK_SECRET=
WEMA_WEBHOOK_SIGNATURE_HEADER=x-wema-signature
WEMA_WEBHOOK_HASH=sha256
WEMA_VIRTUAL_ACCOUNT_PATH=/virtual-accounts
WEMA_BILLS_PAYMENT_PATH=/bills/payment
WEMA_TRANSFER_PATH=/transfers
WEMA_REQUERY_PATH=/transactions/requery
WEMA_TRANSFERS_ENABLED=false

# Email Configuration (Resend - free tier: 3,000 emails/month)
RESEND_API_KEY=re_xxxxx
EMAIL_FROM="Me2U" <onboarding@resend.dev>

# Me2U Guide AI assistant. Server-only key, never expose with NEXT_PUBLIC.
OPENAI_API_KEY=sk-proj-your-openai-api-key
OPENAI_MODEL=gpt-5.2
OPENAI_TIMEOUT_MS=25000
OPENAI_MAX_OUTPUT_TOKENS=900
ASSISTANT_MAX_CONTEXT_SNIPPETS=6
ASSISTANT_DAILY_LIMIT=80

# VTpass bills provider. Server-only; rotate any previously exposed keys before use.
VTPASS_BASE_URL=https://sandbox.vtpass.com/api
VTPASS_PUBLIC_KEY=your-vtpass-public-key
VTPASS_SECRET_KEY=your-vtpass-secret-key
VTPASS_API_KEY=your-vtpass-api-key

# Flutterwave Bills backup provider. Keep disabled until KYC, source balance,
# and static outbound IP whitelisting are complete.
FLUTTERWAVE_BILLS_ENABLED=false
FLUTTERWAVE_SECRET_KEY=your-flutterwave-secret-key
